{
  "manifest_version": 3,
  "name": "Buscador de Preços Kert",
  "version": "1.0.0",
  "description": "Pesquisa preços no Google Web e Shopping usando a sessão local do Chrome.",
  "permissions": ["tabs"],
  "host_permissions": [
    "https://www.google.com/*",
    "https://www.google.com.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Buscador de Preços Kert",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://kertcosmeticos.github.io/Buscador-de-precos/*",
        "http://localhost:5500/*",
        "http://127.0.0.1:5500/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.com.br/search*"
      ],
      "js": ["google-extractor.js"],
      "run_at": "document_idle"
    }
  ]
}
