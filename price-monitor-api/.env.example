PORT=3000
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/price-monitor
# Use true somente para visualizar localmente sem MongoDB ou Mercado Livre.
DEMO_MODE=false
# Necessária para varredura real em múltiplas lojas via Google Shopping.
SERPAPI_KEY=
# CEP único usado para regionalizar preços, estoque e disponibilidade.
SEARCH_POSTAL_CODE=06795-000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-por-uma-senha-forte
JWT_SECRET=gere-uma-chave-aleatoria-longa
# Opcional: origens separadas por vírgula. Vazio libera todas as origens.
CORS_ORIGINS=https://seu-usuario.github.io,http://localhost:5500
